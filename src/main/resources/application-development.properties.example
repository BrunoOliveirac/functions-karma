spring.application.name=karma

# JWT — use a long random string in real environments (never commit the real file)
jwt.secret=change-me-to-a-long-random-secret-key

# DATABASE — adjust host, port, database name, user and password to your local PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/karma_homol
spring.datasource.username=postgres
spring.datasource.password=your-password-here

# JPA
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=update

# FLYWAY — runs SQL migrations on startup
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
